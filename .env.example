# =============================================================================
# TNA System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="TNA System"
APP_ENV=production
APP_URL=https://yourdomain.com
PORT=3000
NODE_ENV=production

# ── Database (MySQL / TiDB) ───────────────────────────────────────────────────
# Full connection string (used by the app and drizzle migrations):
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME?ssl={"rejectUnauthorized":true}

# Individual fields (for reference / manual connection):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tna_system
DB_USER=tna_user
DB_PASSWORD=your_strong_password_here

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars

# ── Manus OAuth (required for login) ─────────────────────────────────────────
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=Your Name

# ── Manus Built-in APIs (LLM, Storage, Notifications) ────────────────────────
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_built_in_forge_api_key
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ── Analytics (optional) ─────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── AI Provider (configured via Admin > AI Settings in the app UI) ─────────────
# Stored in the database — configure after first login at /admin/ai-settings
# Supported: openai | gemini | custom
